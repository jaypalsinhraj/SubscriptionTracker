{
  "_comment": "Copy relevant sections into SubscriptionLeakDetector.Api/appsettings.Production.json or Azure App Settings / Key Vault references.",
  "ConnectionStrings": {
    "DefaultConnection": "Host=YOUR_PG_HOST;Database=subscriptions;Username=YOUR_USER;Password=YOUR_PASSWORD;SSL Mode=Require;Trust Server Certificate=true"
  },
  "AzureAd": {
    "TenantId": "YOUR_ENTRA_EXTERNAL_ID_TENANT_ID",
    "ClientId": "YOUR_API_APP_REGISTRATION_CLIENT_ID",
    "Audience": "api://YOUR_API_APP_ID_OR_APP_ID_URI"
  },
  "Auth": {
    "DevelopmentBypass": {
      "Enabled": false,
      "ExternalUserId": "dev-user"
    }
  },
  "Globalization": {
    "DefaultCulture": "en-US",
    "DefaultCurrency": "USD"
  },
  "Cors": {
    "Origins": [ "https://YOUR_STATIC_WEB_APP_HOST" ]
  },
  "AzureStorage": {
    "ConnectionString": "@Microsoft.KeyVault(SecretUri=https://YOUR_VAULT.vault.azure.net/secrets/storage-conn/)",
    "ImportsContainer": "imports"
  }
}
