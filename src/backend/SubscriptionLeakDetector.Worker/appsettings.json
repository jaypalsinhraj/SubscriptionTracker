{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [ { "Name": "Console" } ]
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=subscription_tracker;Username=postgres;Password=postgres"
  },
  "Worker": {
    "IntervalMinutes": 60
  },
  "AzureStorage": {
    "ConnectionString": "",
    "ImportsContainer": "imports"
  }
}
