{
  "Globalization": {
    "DefaultCulture": "en-GB",
    "DefaultCurrency": "GBP"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
        "SubscriptionLeakDetector": "Debug"
      }
    }
  },
  "Auth": {
    "DevelopmentBypass": {
      "Enabled": true,
      "ExternalUserId": "dev-user"
    }
  }
}
