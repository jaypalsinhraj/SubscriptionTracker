{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext}{NewLine}{Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=subscription_tracker;Username=postgres;Password=postgres"
  },
  "Globalization": {
    "DefaultCulture": "en-GB",
    "DefaultCurrency": "GBP"
  },
  "Cors": {
    "Origins": [ "http://localhost:5173" ]
  },
  "AzureAd": {
    "TenantId": "",
    "ClientId": "",
    "Audience": ""
  },
  "Auth": {
    "DevelopmentBypass": {
      "Enabled": false,
      "ExternalUserId": "dev-user"
    }
  },
  "AzureStorage": {
    "ConnectionString": "",
    "ImportsContainer": "imports"
  }
}
