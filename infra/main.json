{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.41.2.15936",
      "templateHash": "18433187928124830839"
    }
  },
  "parameters": {
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Single Azure region for all resources."
      }
    },
    "namePrefix": {
      "type": "string",
      "metadata": {
        "description": "Prefix for resource names (lowercase, no spaces)."
      }
    },
    "postgresAdminLogin": {
      "type": "string",
      "metadata": {
        "description": "PostgreSQL administrator login."
      }
    },
    "postgresAdminPassword": {
      "type": "securestring",
      "metadata": {
        "description": "PostgreSQL administrator password."
      }
    },
    "apiImage": {
      "type": "string",
      "metadata": {
        "description": "Container image for the API (ACR login server + repository:tag)."
      }
    },
    "workerImage": {
      "type": "string",
      "metadata": {
        "description": "Container image for the worker job."
      }
    }
  },
  "variables": {
    "sanitized": "[replace(toLower(parameters('namePrefix')), '-', '')]",
    "logAnalyticsName": "[format('{0}-logs', variables('sanitized'))]",
    "acrNameResolved": "[format('{0}acr', variables('sanitized'))]",
    "kvName": "[take(format('{0}kv{1}', variables('sanitized'), uniqueString(resourceGroup().id)), 24)]",
    "storageName": "[take(replace(format('{0}st{1}', variables('sanitized'), uniqueString(resourceGroup().id)), '-', ''), 24)]",
    "pgName": "[format('{0}-pg', variables('sanitized'))]",
    "caeName": "[format('{0}-cae', variables('sanitized'))]",
    "apiAppName": "[format('{0}-api', variables('sanitized'))]",
    "workerJobName": "[format('{0}-worker', variables('sanitized'))]",
    "swaName": "[format('{0}-web', variables('sanitized'))]"
  },
  "resources": [
    {
      "type": "Microsoft.OperationalInsights/workspaces",
      "apiVersion": "2022-10-01",
      "name": "[variables('logAnalyticsName')]",
      "location": "[parameters('location')]",
      "properties": {
        "sku": {
          "name": "PerGB2018"
        },
        "retentionInDays": 30
      }
    },
    {
      "type": "Microsoft.ContainerRegistry/registries",
      "apiVersion": "2023-07-01",
      "name": "[variables('acrNameResolved')]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "Basic"
      },
      "properties": {
        "adminUserEnabled": false,
        "publicNetworkAccess": "Enabled"
      }
    },
    {
      "type": "Microsoft.Storage/storageAccounts",
      "apiVersion": "2023-01-01",
      "name": "[variables('storageName')]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "Standard_LRS"
      },
      "kind": "StorageV2",
      "properties": {
        "allowBlobPublicAccess": false,
        "minimumTlsVersion": "TLS1_2"
      }
    },
    {
      "type": "Microsoft.KeyVault/vaults",
      "apiVersion": "2023-07-01",
      "name": "[variables('kvName')]",
      "location": "[parameters('location')]",
      "properties": {
        "sku": {
          "family": "A",
          "name": "standard"
        },
        "tenantId": "[subscription().tenantId]",
        "enableRbacAuthorization": true,
        "enabledForDeployment": false,
        "enabledForTemplateDeployment": true,
        "enabledForDiskEncryption": false
      }
    },
    {
      "type": "Microsoft.DBforPostgreSQL/flexibleServers",
      "apiVersion": "2023-12-01-preview",
      "name": "[variables('pgName')]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "Standard_B1ms",
        "tier": "Burstable"
      },
      "properties": {
        "version": "16",
        "administratorLogin": "[parameters('postgresAdminLogin')]",
        "administratorLoginPassword": "[parameters('postgresAdminPassword')]",
        "storage": {
          "storageSizeGB": 32
        },
        "backup": {
          "backupRetentionDays": 7,
          "geoRedundantBackup": "Disabled"
        },
        "highAvailability": {
          "mode": "Disabled"
        },
        "network": {
          "publicNetworkAccess": "Enabled"
        }
      }
    },
    {
      "type": "Microsoft.DBforPostgreSQL/flexibleServers/firewallRules",
      "apiVersion": "2023-12-01-preview",
      "name": "[format('{0}/{1}', variables('pgName'), 'allow-all-for-mvp')]",
      "properties": {
        "startIpAddress": "0.0.0.0",
        "endIpAddress": "255.255.255.255"
      },
      "dependsOn": [
        "[resourceId('Microsoft.DBforPostgreSQL/flexibleServers', variables('pgName'))]"
      ]
    },
    {
      "type": "Microsoft.DBforPostgreSQL/flexibleServers/databases",
      "apiVersion": "2023-12-01-preview",
      "name": "[format('{0}/{1}', variables('pgName'), 'subscriptions')]",
      "properties": {
        "charset": "UTF8",
        "collation": "en_US.utf8"
      },
      "dependsOn": [
        "[resourceId('Microsoft.DBforPostgreSQL/flexibleServers', variables('pgName'))]"
      ]
    },
    {
      "type": "Microsoft.App/managedEnvironments",
      "apiVersion": "2024-03-01",
      "name": "[variables('caeName')]",
      "location": "[parameters('location')]",
      "properties": {
        "appLogsConfiguration": {
          "destination": "log-analytics",
          "logAnalyticsConfiguration": {
            "customerId": "[reference(resourceId('Microsoft.OperationalInsights/workspaces', variables('logAnalyticsName')), '2022-10-01').customerId]",
            "sharedKey": "[listKeys(resourceId('Microsoft.OperationalInsights/workspaces', variables('logAnalyticsName')), '2022-10-01').primarySharedKey]"
          }
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.OperationalInsights/workspaces', variables('logAnalyticsName'))]"
      ]
    },
    {
      "type": "Microsoft.ManagedIdentity/userAssignedIdentities",
      "apiVersion": "2023-01-31",
      "name": "[format('{0}-api-id', variables('sanitized'))]",
      "location": "[parameters('location')]"
    },
    {
      "type": "Microsoft.ManagedIdentity/userAssignedIdentities",
      "apiVersion": "2023-01-31",
      "name": "[format('{0}-worker-id', variables('sanitized'))]",
      "location": "[parameters('location')]"
    },
    {
      "type": "Microsoft.App/containerApps",
      "apiVersion": "2024-03-01",
      "name": "[variables('apiAppName')]",
      "location": "[parameters('location')]",
      "identity": {
        "type": "UserAssigned",
        "userAssignedIdentities": {
          "[format('{0}', resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('{0}-api-id', variables('sanitized'))))]": {}
        }
      },
      "properties": {
        "managedEnvironmentId": "[resourceId('Microsoft.App/managedEnvironments', variables('caeName'))]",
        "configuration": {
          "ingress": {
            "external": true,
            "targetPort": 8080,
            "transport": "Auto"
          },
          "registries": [
            {
              "server": "[reference(resourceId('Microsoft.ContainerRegistry/registries', variables('acrNameResolved')), '2023-07-01').loginServer]",
              "identity": "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('{0}-api-id', variables('sanitized')))]"
            }
          ]
        },
        "template": {
          "containers": [
            {
              "name": "api",
              "image": "[parameters('apiImage')]",
              "env": [
                {
                  "name": "ConnectionStrings__DefaultConnection",
                  "value": "[format('Host={0};Database=subscriptions;Username={1};Password={2};SSL Mode=Require;Trust Server Certificate=true', reference(resourceId('Microsoft.DBforPostgreSQL/flexibleServers', variables('pgName')), '2023-12-01-preview').fullyQualifiedDomainName, parameters('postgresAdminLogin'), parameters('postgresAdminPassword'))]"
                },
                {
                  "name": "ASPNETCORE_URLS",
                  "value": "http://+:8080"
                }
              ],
              "resources": {
                "cpu": "[json('0.5')]",
                "memory": "1Gi"
              }
            }
          ],
          "scale": {
            "minReplicas": 0,
            "maxReplicas": 3
          }
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.ContainerRegistry/registries', variables('acrNameResolved'))]",
        "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('{0}-api-id', variables('sanitized')))]",
        "[resourceId('Microsoft.App/managedEnvironments', variables('caeName'))]",
        "[resourceId('Microsoft.DBforPostgreSQL/flexibleServers', variables('pgName'))]"
      ]
    },
    {
      "type": "Microsoft.App/jobs",
      "apiVersion": "2024-02-02-preview",
      "name": "[variables('workerJobName')]",
      "location": "[parameters('location')]",
      "identity": {
        "type": "UserAssigned",
        "userAssignedIdentities": {
          "[format('{0}', resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('{0}-worker-id', variables('sanitized'))))]": {}
        }
      },
      "properties": {
        "environmentId": "[resourceId('Microsoft.App/managedEnvironments', variables('caeName'))]",
        "configuration": {
          "triggerType": "Schedule",
          "scheduleTriggerConfig": {
            "cronExpression": "0 * * * *",
            "parallelism": 1,
            "replicaCompletionCount": 1
          },
          "replicaTimeout": 1800,
          "replicaRetryLimit": 1,
          "registries": [
            {
              "server": "[reference(resourceId('Microsoft.ContainerRegistry/registries', variables('acrNameResolved')), '2023-07-01').loginServer]",
              "identity": "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('{0}-worker-id', variables('sanitized')))]"
            }
          ]
        },
        "template": {
          "containers": [
            {
              "name": "worker",
              "image": "[parameters('workerImage')]",
              "env": [
                {
                  "name": "ConnectionStrings__DefaultConnection",
                  "value": "[format('Host={0};Database=subscriptions;Username={1};Password={2};SSL Mode=Require;Trust Server Certificate=true', reference(resourceId('Microsoft.DBforPostgreSQL/flexibleServers', variables('pgName')), '2023-12-01-preview').fullyQualifiedDomainName, parameters('postgresAdminLogin'), parameters('postgresAdminPassword'))]"
                },
                {
                  "name": "Worker__IntervalMinutes",
                  "value": "60"
                }
              ],
              "resources": {
                "cpu": "[json('0.25')]",
                "memory": "0.5Gi"
              }
            }
          ]
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.ContainerRegistry/registries', variables('acrNameResolved'))]",
        "[resourceId('Microsoft.App/managedEnvironments', variables('caeName'))]",
        "[resourceId('Microsoft.DBforPostgreSQL/flexibleServers', variables('pgName'))]",
        "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('{0}-worker-id', variables('sanitized')))]"
      ]
    },
    {
      "type": "Microsoft.Web/staticSites",
      "apiVersion": "2022-09-01",
      "name": "[variables('swaName')]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "Standard",
        "tier": "Standard"
      },
      "properties": {
        "provider": "None",
        "stagingEnvironmentPolicy": "Enabled",
        "buildProperties": {
          "skipGithubActionWorkflowGeneration": true
        }
      }
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "scope": "[resourceId('Microsoft.ContainerRegistry/registries', variables('acrNameResolved'))]",
      "name": "[guid(resourceId('Microsoft.ContainerRegistry/registries', variables('acrNameResolved')), resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('{0}-api-id', variables('sanitized'))), 'acrpull')]",
      "properties": {
        "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', '7f951dda-4ed3-4680-a7ca-43fe172d538d')]",
        "principalId": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('{0}-api-id', variables('sanitized'))), '2023-01-31').principalId]",
        "principalType": "ServicePrincipal"
      },
      "dependsOn": [
        "[resourceId('Microsoft.ContainerRegistry/registries', variables('acrNameResolved'))]",
        "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('{0}-api-id', variables('sanitized')))]"
      ]
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "scope": "[resourceId('Microsoft.ContainerRegistry/registries', variables('acrNameResolved'))]",
      "name": "[guid(resourceId('Microsoft.ContainerRegistry/registries', variables('acrNameResolved')), resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('{0}-worker-id', variables('sanitized'))), 'acrpull')]",
      "properties": {
        "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', '7f951dda-4ed3-4680-a7ca-43fe172d538d')]",
        "principalId": "[reference(resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('{0}-worker-id', variables('sanitized'))), '2023-01-31').principalId]",
        "principalType": "ServicePrincipal"
      },
      "dependsOn": [
        "[resourceId('Microsoft.ContainerRegistry/registries', variables('acrNameResolved'))]",
        "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('{0}-worker-id', variables('sanitized')))]"
      ]
    }
  ],
  "outputs": {
    "logAnalyticsWorkspaceId": {
      "type": "string",
      "value": "[resourceId('Microsoft.OperationalInsights/workspaces', variables('logAnalyticsName'))]"
    },
    "acrLoginServer": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.ContainerRegistry/registries', variables('acrNameResolved')), '2023-07-01').loginServer]"
    },
    "keyVaultName": {
      "type": "string",
      "value": "[variables('kvName')]"
    },
    "postgresFqdn": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.DBforPostgreSQL/flexibleServers', variables('pgName')), '2023-12-01-preview').fullyQualifiedDomainName]"
    },
    "apiFqdn": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.App/containerApps', variables('apiAppName')), '2024-03-01').configuration.ingress.fqdn]"
    },
    "staticWebAppName": {
      "type": "string",
      "value": "[variables('swaName')]"
    },
    "staticWebAppHost": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Web/staticSites', variables('swaName')), '2022-09-01').defaultHostname]"
    }
  }
}